[init]
  defaultBranch = main

[color]
  ui = true
  diff = auto
  status = auto
  branch = auto

[push]
  default = current
  autoSetupRemote = true

[pull]
  ff = only
  rebase = true

[remote]
  pushDefault = origin

[rebase]
  autoStash = true

[fetch]
  prune = true

[include]
  path = ~/.config/git/config.local
