window-padding-balance = true
config-file = doubletrouble
font-family = Rec Mono Custom
font-size = 12.5
window-padding-y = 0
macos-titlebar-style = hidden
macos-option-as-alt = true

# tmux
## sessions
keybind = super+p=text:\x02t
keybind = super+l=text:\x02L

## tabs
keybind = super+digit_1=text:\x021
keybind = super+digit_2=text:\x022
keybind = super+digit_3=text:\x023
keybind = super+digit_4=text:\x024
keybind = super+digit_5=text:\x025

## windows/panes/tabs
keybind = super+z=text:\x02z
keybind = super+t=text:\x02c
keybind = super+d=text:\x02!
