#!/bin/sh
kitty_ls=$(kitty @ ls)

sessions=$(
  printf '%s' "$kitty_ls" |
  jq --raw-output '.[].wm_name' |
  sort
)

[ -n "$sessions" ] || exit 0

result=$(
  printf '%s' "$sessions" |
  fzf --cycle --layout=reverse --multi --print-query --expect=alt-n,alt-x \
    --header="enter: focus | alt-n: new session | alt-x: close | tab: mark"
)

[ -n "$result" ] || exit 0

query=$(printf '%s\n' "$result" | head -1)
key=$(printf '%s\n' "$result" | sed -n '2p')
selected=$(printf '%s\n' "$result" | tail -n +3)

case "$key" in
  alt-n)
    [ -n "$query" ] || exit 0
    kitty @ launch --type=os-window --os-window-name="$query"
    exit 0
    ;;
  alt-x)
    [ -n "$selected" ] || exit 0
    printf 'Delete sessions:\n'
    printf '%s\n' "$selected" | sed 's/^/  /'
    printf 'Confirm? [y/N] '
    read -r confirm
    [ "$confirm" = "y" ] || exit 0

    printf '%s\n' "$selected" | while read -r session; do
      kitty-close-session "$session"
    done
    ;;
  *)
    [ -n "$selected" ] || exit 0
    session=$(printf '%s\n' "$selected" | head -1)
    id_to_focus=$(
      printf '%s' "$kitty_ls" |
      jq --arg wm_name "$session" 'first(.[] | select(.wm_name == $wm_name) | .tabs[] | select(.is_active) | .windows[] | select(.is_active) | .id)'
    )
    kitty @ focus-window --match=id:$id_to_focus
    ;;
esac
