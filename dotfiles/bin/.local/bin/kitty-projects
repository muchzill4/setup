#!/bin/sh
PROJECTS_PATH="$HOME/Dev"
SESSION_PREFIX="+ "

kitty_ls=$(kitty @ ls)

sessions=$(
  printf '%s' "$kitty_ls" |
  jq --raw-output '.[].wm_name' |
  sort
)

projects=$(
  find "$PROJECTS_PATH"/* -maxdepth 1 -mindepth 1 -type d |
  sed "s‾$PROJECTS_PATH/‾‾" |
  sort
)

worktrees=$(
  for wt in "$PROJECTS_PATH"/*/*/.worktrees/*/; do
    [ -d "$wt" ] || continue
    project="${wt#$PROJECTS_PATH/}"
    project="${project%%/.worktrees/*}"
    name="${wt%/}"
    name="${name##*/}"
    printf '%s @ %s¥n' "$project" "$name"
  done | sort
)

all_projects="$projects"
if [ -n "$worktrees" ]; then
  all_projects="$projects
$worktrees"
fi

projects_without_sessions=$(printf '%s' "$all_projects" | grep -vxF "$sessions")
if [ -n "$sessions" ]; then
  prefixed_sessions=$(printf '%s' "$sessions" | sed "s‾^‾$SESSION_PREFIX‾")
  options="$prefixed_sessions
$projects_without_sessions"
else
  options=$projects_without_sessions
fi

result=$(
  printf '%s' "$options" |
  fzf --cycle --layout=reverse --print-query --expect=alt-n ¥
    --header="enter: open | alt-n: new session"
)

[ -n "$result" ] || exit 0

query=$(printf '%s¥n' "$result" | head -1)
key=$(printf '%s¥n' "$result" | sed -n '2p')
selected=$(printf '%s¥n' "$result" | sed -n '3p')

case "$key" in
  alt-n)
    [ -n "$query" ] || exit 0
    kitty @ launch --type=os-window --os-window-name="$query"
    ;;
  *)
    [ -n "$selected" ] || exit 0
    case "$selected" in
      "$SESSION_PREFIX"*)
        session_name="${selected#$SESSION_PREFIX}"
        id_to_focus=$(
          printf '%s' "$kitty_ls" |
          jq --arg wm_name "$session_name" 'first(.[] | select(.wm_name == $wm_name) | .tabs[] | select(.is_active) | .windows[] | select(.is_active) | .id)'
        )
        kitty @ focus-window --match=id:$id_to_focus
        ;;
      *" @ "*)
        project="${selected%% @ *}"
        wt_name="${selected#* @ }"
        directory="$PROJECTS_PATH/$project/.worktrees/$wt_name"
        kitty @ launch --type=os-window --os-window-name="$selected" --cwd="$directory"
        ;;
      *)
        directory="$PROJECTS_PATH/$selected"
        kitty @ launch --type=os-window --os-window-name="$selected" --cwd="$directory"
        ;;
    esac
    ;;
esac
